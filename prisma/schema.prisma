generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum FixtureStatus {
  SCHEDULED
  LIVE
  FINISHED
  POSTPONED
  CANCELLED
}

enum FavoriteEntityType {
  FIXTURE
  TEAM
  COMPETITION
}

enum NotificationType {
  GOAL
  CARD
  KICKOFF
  PERIOD_CHANGE
  FINAL_RESULT
  NEWS
}

enum ArticleEntityType {
  SPORT
  COUNTRY
  COMPETITION
  TEAM
  FIXTURE
}

enum NewsArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum FixtureParticipantType {
  TEAM
  PLAYER
  OFFICIAL
}

enum FixtureSide {
  HOME
  AWAY
  NEUTRAL
}

enum SyncJobStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

model User {
  id                        String                   @id @default(cuid())
  email                     String                   @unique
  username                  String                   @unique
  passwordHash              String
  displayName               String?
  isActive                  Boolean                  @default(true)
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt
  sessions                  Session[]
  accounts                  Account[]
  roles                     UserRole[]
  preferences               UserPreference[]
  favorites                 FavoriteEntity[]
  notificationSubscriptions NotificationSubscription[]
  recentViews               RecentView[]
  auditLogs                 AuditLog[]
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  tokenHash    String   @unique
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  lastSeenAt   DateTime?
  revokedAt    DateTime?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  accessToken       String?  @db.Text
  refreshToken      String?  @db.Text
  expiresAt         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String           @id @default(cuid())
  code        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  roles       RolePermission[]
}

model UserRole {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  assignedAt   DateTime   @default(now())
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserPreference {
  id         String   @id @default(cuid())
  userId     String
  key        String
  value      Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
}

model SourceProvider {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  kind        String?
  isActive    Boolean  @default(true)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, code])
}

model Sport {
  id          String   @id @default(cuid())
  code        String   @unique
  slug        String   @unique
  name        String
  isEnabled   Boolean  @default(true)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  competitions Competition[]
  leagues     League[]
  fixtures    Fixture[]

  @@index([isEnabled, name])
}

model Country {
  id           String   @id @default(cuid())
  code         String   @unique
  slug         String   @unique
  name         String
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  competitions Competition[]
  leagues      League[]
  fixtures     Fixture[]

  @@index([name])
}

model Competition {
  id          String   @id @default(cuid())
  sportId     String
  countryId   String?
  name        String
  shortName   String?
  slug        String   @unique
  code        String?  @unique
  externalRef String?  @unique
  logoUrl     String?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  sport       Sport    @relation(fields: [sportId], references: [id], onDelete: Cascade)
  country     Country? @relation(fields: [countryId], references: [id], onDelete: SetNull)
  leagues     League[]
  seasons     Season[]
  teams       Team[]
  fixtures    Fixture[]
  standings   Standing[]

  @@index([sportId, countryId, name])
}

model FavoriteEntity {
  id         String             @id @default(cuid())
  userId     String
  entityType FavoriteEntityType
  entityId   String
  label      String?
  metadata   Json?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, entityType, entityId])
  @@index([entityType, entityId])
}

model NotificationSubscription {
  id               String             @id @default(cuid())
  userId           String
  entityType       FavoriteEntityType
  entityId         String
  notificationType NotificationType
  isEnabled        Boolean            @default(true)
  metadata         Json?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, entityType, entityId, notificationType])
  @@index([entityType, entityId, notificationType])
}

model RecentView {
  id         String             @id @default(cuid())
  userId     String
  entityType FavoriteEntityType
  entityId   String
  label      String?
  metadata   Json?
  viewedAt   DateTime           @default(now())
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, entityType, entityId])
  @@index([userId, viewedAt])
}

model League {
  id            String       @id @default(cuid())
  sportId       String?
  countryId     String?
  competitionId String?
  name          String
  country       String?
  code          String       @unique
  provider      String?
  externalRef   String?      @unique
  logoUrl       String?
  metadata      Json?
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  sport         Sport?       @relation(fields: [sportId], references: [id], onDelete: SetNull)
  countryRecord Country?     @relation(fields: [countryId], references: [id], onDelete: SetNull)
  competition   Competition? @relation(fields: [competitionId], references: [id], onDelete: SetNull)
  seasons       Season[]
  teams         Team[]
  fixtures      Fixture[]

  @@index([isActive, name])
}

model Season {
  id            String       @id @default(cuid())
  leagueId      String
  competitionId String?
  name          String
  provider      String?
  externalRef   String?      @unique
  startDate     DateTime
  endDate       DateTime
  metadata      Json?
  isCurrent     Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  league        League       @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  competition   Competition? @relation(fields: [competitionId], references: [id], onDelete: SetNull)
  fixtures      Fixture[]
  standings     Standing[]

  @@unique([leagueId, name])
  @@index([leagueId, isCurrent])
}

model Team {
  id            String              @id @default(cuid())
  leagueId      String?
  competitionId String?
  name          String
  shortName     String?
  code          String?
  provider      String?
  externalRef   String?             @unique
  logoUrl       String?
  metadata      Json?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  league        League?             @relation(fields: [leagueId], references: [id], onDelete: SetNull)
  competition   Competition?        @relation(fields: [competitionId], references: [id], onDelete: SetNull)
  homeFor       Fixture[]           @relation("HomeTeam")
  awayFor       Fixture[]           @relation("AwayTeam")
  fixtureParticipants FixtureParticipant[]
  standings     Standing[]
  lineupEntries Lineup[]
  incidents     Incident[]
  statistics    Statistic[]

  @@unique([leagueId, name])
  @@index([name])
}

model Venue {
  id          String   @id @default(cuid())
  name        String
  city        String?
  countryName String?
  capacity    Int?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  fixtures    Fixture[]

  @@index([name, city])
  @@unique([name, city])
}

model Player {
  id           String   @id @default(cuid())
  name         String
  shortName    String?
  externalRef  String?  @unique
  countryName  String?
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  participants FixtureParticipant[]
  lineupEntries Lineup[]
  incidents    Incident[]

  @@index([name])
}

model Official {
  id           String   @id @default(cuid())
  name         String
  role         String?
  externalRef  String?  @unique
  countryName  String?
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  participants FixtureParticipant[]

  @@index([name])
}

model Fixture {
  id                String               @id @default(cuid())
  sportId           String?
  countryId         String?
  competitionId     String?
  leagueId          String
  seasonId          String
  venueId           String?
  homeTeamId        String
  awayTeamId        String
  provider          String?
  startsAt          DateTime
  status            FixtureStatus        @default(SCHEDULED)
  venue             String?
  externalRef       String?              @unique
  round             String?
  stateReason       String?
  lastSyncedAt      DateTime?
  metadata          Json?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  sport             Sport?               @relation(fields: [sportId], references: [id], onDelete: SetNull)
  countryRecord     Country?             @relation(fields: [countryId], references: [id], onDelete: SetNull)
  competition       Competition?         @relation(fields: [competitionId], references: [id], onDelete: SetNull)
  league            League               @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  season            Season               @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  venueRecord       Venue?               @relation(fields: [venueId], references: [id], onDelete: SetNull)
  homeTeam          Team                 @relation("HomeTeam", fields: [homeTeamId], references: [id], onDelete: Restrict)
  awayTeam          Team                 @relation("AwayTeam", fields: [awayTeamId], references: [id], onDelete: Restrict)
  standings         Standing[]
  participants      FixtureParticipant[]
  incidents         Incident[]
  lineups           Lineup[]
  statistics        Statistic[]
  h2hSnapshots      H2HSnapshot[]
  broadcastChannels BroadcastChannel[]
  oddsMarkets       OddsMarket[]
  resultSnapshot    ResultSnapshot?

  @@index([status, startsAt])
  @@index([leagueId, seasonId, startsAt])
}

model Standing {
  id            String       @id @default(cuid())
  seasonId      String
  competitionId String?
  fixtureId     String?
  teamId        String
  position      Int
  played        Int          @default(0)
  won           Int          @default(0)
  drawn         Int          @default(0)
  lost          Int          @default(0)
  goalsFor      Int          @default(0)
  goalsAgainst  Int          @default(0)
  points        Int          @default(0)
  updatedAt     DateTime     @updatedAt
  season        Season       @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  competition   Competition? @relation(fields: [competitionId], references: [id], onDelete: SetNull)
  fixture       Fixture?     @relation(fields: [fixtureId], references: [id], onDelete: SetNull)
  team          Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([seasonId, teamId])
  @@index([seasonId, position])
}

model OddsMarket {
  id            String          @id @default(cuid())
  fixtureId      String
  provider      String?
  externalRef   String?         @unique
  bookmaker      String
  marketType     String
  suspended      Boolean         @default(false)
  lastSyncedAt   DateTime?
  metadata      Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  fixture        Fixture         @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
  selections     OddsSelection[]

  @@index([fixtureId, bookmaker])
  @@index([bookmaker, marketType])
}

model OddsSelection {
  id              String      @id @default(cuid())
  oddsMarketId    String
  externalRef     String?     @unique
  label           String
  line            Decimal?    @db.Decimal(10, 2)
  priceDecimal    Decimal     @db.Decimal(10, 4)
  isActive        Boolean     @default(true)
  metadata        Json?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  oddsMarket      OddsMarket  @relation(fields: [oddsMarketId], references: [id], onDelete: Cascade)

  @@index([oddsMarketId, isActive])
}

model ResultSnapshot {
  id              String   @id @default(cuid())
  fixtureId       String   @unique
  homeScore       Int
  awayScore       Int
  statusText      String?
  payload         Json?
  capturedAt      DateTime @default(now())
  fixture         Fixture  @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
}

model FixtureParticipant {
  id         String                 @id @default(cuid())
  fixtureId  String
  teamId     String?
  playerId   String?
  officialId String?
  type       FixtureParticipantType
  side       FixtureSide?
  role       String?
  sortOrder  Int                    @default(0)
  metadata   Json?
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt
  fixture    Fixture                @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
  team       Team?                  @relation(fields: [teamId], references: [id], onDelete: SetNull)
  player     Player?                @relation(fields: [playerId], references: [id], onDelete: SetNull)
  official   Official?              @relation(fields: [officialId], references: [id], onDelete: SetNull)
  incidents  Incident[]

  @@index([fixtureId, side, sortOrder])
}

model Incident {
  id           String      @id @default(cuid())
  fixtureId    String
  participantId String?
  teamId       String?
  playerId     String?
  minute       Int?
  extraMinute  Int?
  sortOrder    Int         @default(0)
  side         FixtureSide?
  type         String
  title        String
  description  String?     @db.Text
  payload      Json?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  fixture      Fixture     @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
  participant  FixtureParticipant? @relation(fields: [participantId], references: [id], onDelete: SetNull)
  team         Team?       @relation(fields: [teamId], references: [id], onDelete: SetNull)
  player       Player?     @relation(fields: [playerId], references: [id], onDelete: SetNull)

  @@index([fixtureId, minute, sortOrder])
}

model Lineup {
  id            String      @id @default(cuid())
  fixtureId      String
  teamId         String
  playerId       String?
  side           FixtureSide?
  entryType      String?
  jerseyNumber   String?
  formationSlot  String?
  positionLabel  String?
  isStarter      Boolean     @default(false)
  sortOrder      Int         @default(0)
  metadata       Json?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  fixture        Fixture     @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
  team           Team        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  player         Player?     @relation(fields: [playerId], references: [id], onDelete: SetNull)

  @@index([fixtureId, teamId, sortOrder])
}

model Statistic {
  id           String      @id @default(cuid())
  fixtureId     String
  teamId        String?
  side          FixtureSide?
  name          String
  statGroup     String?
  period        String?
  value         String?
  sortOrder     Int         @default(0)
  metadata      Json?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  fixture       Fixture     @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
  team          Team?       @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@index([fixtureId, name, sortOrder])
}

model H2HSnapshot {
  id          String   @id @default(cuid())
  fixtureId    String
  homeTeamId   String
  awayTeamId   String
  payload      Json?
  capturedAt   DateTime @default(now())
  fixture      Fixture  @relation(fields: [fixtureId], references: [id], onDelete: Cascade)

  @@index([fixtureId, capturedAt])
}

model BroadcastChannel {
  id          String   @id @default(cuid())
  fixtureId    String
  name        String
  territory   String?
  channelType String?
  url         String?
  isActive    Boolean  @default(true)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  fixture     Fixture  @relation(fields: [fixtureId], references: [id], onDelete: Cascade)

  @@index([fixtureId, territory])
}

model NewsCategory {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  articles    NewsArticle[]
}

model NewsArticle {
  id          String            @id @default(cuid())
  categoryId  String?
  slug        String            @unique
  title       String
  excerpt     String?           @db.Text
  body        String?           @db.LongText
  status      NewsArticleStatus @default(DRAFT)
  sourceUrl   String?
  imageUrl    String?
  publishedAt DateTime?
  metadata    Json?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  category    NewsCategory?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  entityLinks ArticleEntityLink[]

  @@index([status, publishedAt])
}

model ArticleEntityLink {
  id         String            @id @default(cuid())
  articleId   String
  entityType  ArticleEntityType
  entityId    String
  label       String?
  createdAt   DateTime         @default(now())
  article     NewsArticle      @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, entityType, entityId])
  @@index([entityType, entityId])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  action      String
  entityType  String
  entityId    String
  metadata    Json?
  createdAt   DateTime @default(now())
  actor       User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId, createdAt])
}

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  description String?
  enabled     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SyncJob {
  id            String        @id @default(cuid())
  provider      String        @default("SPORTSMONKS")
  source        String
  bucket        String        @default("manual")
  recordsProcessed Int        @default(0)
  resultSummary Json?
  status        SyncJobStatus @default(PENDING)
  startedAt     DateTime?
  finishedAt    DateTime?
  errorMessage  String?       @db.Text
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  checkpoints   SyncCheckpoint[]

  @@index([source, status, createdAt])
  @@index([provider, bucket, createdAt])
}

model SyncCheckpoint {
  id            String   @id @default(cuid())
  provider      String   @default("SPORTSMONKS")
  key           String
  syncJobId     String?
  cursor        String?
  payload       Json?
  errorMessage  String?  @db.Text
  lastSuccessAt DateTime?
  lastFailureAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  syncJob       SyncJob? @relation(fields: [syncJobId], references: [id], onDelete: SetNull)

  @@unique([provider, key])
  @@index([provider, updatedAt])
}
