generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum FixtureStatus {
  SCHEDULED
  LIVE
  FINISHED
  POSTPONED
  CANCELLED
}

enum InsightVisibility {
  PUBLIC
  FOLLOWERS
  PRIVATE
}

enum ReportStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  REJECTED
}

enum ModerationActionType {
  WARNING
  CONTENT_REMOVAL
  TEMP_BAN
  PERM_BAN
}

enum BettingSlipStatus {
  DRAFT
  PUBLISHED
  SETTLED
  VOID
}

enum PurchaseStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum OutcomeStatus {
  OPEN
  WON
  LOST
  VOID
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum OrderStatus {
  CREATED
  PAID
  CANCELLED
  REFUNDED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  VOID
}

enum SyncJobStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

model User {
  id                String                @id @default(cuid())
  email             String                @unique
  username          String                @unique
  passwordHash      String
  displayName       String?
  isActive          Boolean               @default(true)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  sessions          Session[]
  accounts          Account[]
  roles             UserRole[]
  preferences       UserPreference[]
  creatorProfile    CreatorProfile?
  insights          InsightPost[]
  comments          InsightComment[]
  likes             InsightLike[]
  reportsFiled      Report[]              @relation("ReportReporter")
  reportsAgainst    Report[]              @relation("ReportTarget")
  moderationActions ModerationAction[]    @relation("ModerationTarget")
  purchases         BettingSlipPurchase[]
  payments          Payment[]
  orders            Order[]
  auditLogs         AuditLog[]
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  tokenHash    String   @unique
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  lastSeenAt   DateTime?
  revokedAt    DateTime?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  accessToken       String?  @db.Text
  refreshToken      String?  @db.Text
  expiresAt         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String           @id @default(cuid())
  code        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  roles       RolePermission[]
}

model UserRole {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  assignedAt   DateTime   @default(now())
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserPreference {
  id         String   @id @default(cuid())
  userId     String
  key        String
  value      Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
}

model League {
  id         String   @id @default(cuid())
  name       String
  country    String?
  code       String   @unique
  provider   String?
  externalRef String? @unique
  logoUrl    String?
  metadata   Json?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  seasons    Season[]
  teams      Team[]
  fixtures   Fixture[]

  @@index([isActive, name])
}

model Season {
  id         String   @id @default(cuid())
  leagueId   String
  name       String
  provider   String?
  externalRef String? @unique
  startDate  DateTime
  endDate    DateTime
  metadata   Json?
  isCurrent  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  league     League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  fixtures   Fixture[]
  standings  Standing[]

  @@unique([leagueId, name])
  @@index([leagueId, isCurrent])
}

model Team {
  id         String   @id @default(cuid())
  leagueId   String?
  name       String
  shortName  String?
  code       String?
  provider   String?
  externalRef String? @unique
  logoUrl    String?
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  league     League?  @relation(fields: [leagueId], references: [id], onDelete: SetNull)
  homeFor    Fixture[] @relation("HomeTeam")
  awayFor    Fixture[] @relation("AwayTeam")
  standings  Standing[]

  @@unique([leagueId, name])
  @@index([name])
}

model Fixture {
  id             String         @id @default(cuid())
  leagueId       String
  seasonId       String
  homeTeamId     String
  awayTeamId     String
  provider       String?
  startsAt       DateTime
  status         FixtureStatus  @default(SCHEDULED)
  venue          String?
  externalRef    String?        @unique
  round          String?
  stateReason    String?
  lastSyncedAt   DateTime?
  metadata       Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  league         League         @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  season         Season         @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  homeTeam       Team           @relation("HomeTeam", fields: [homeTeamId], references: [id], onDelete: Restrict)
  awayTeam       Team           @relation("AwayTeam", fields: [awayTeamId], references: [id], onDelete: Restrict)
  standings      Standing[]
  oddsMarkets    OddsMarket[]
  resultSnapshot ResultSnapshot?
  slipSelections BettingSlipSelection[]

  @@index([status, startsAt])
  @@index([leagueId, seasonId, startsAt])
}

model Standing {
  id           String   @id @default(cuid())
  seasonId     String
  fixtureId    String?
  teamId       String
  position     Int
  played       Int      @default(0)
  won          Int      @default(0)
  drawn        Int      @default(0)
  lost         Int      @default(0)
  goalsFor     Int      @default(0)
  goalsAgainst Int      @default(0)
  points       Int      @default(0)
  updatedAt    DateTime @updatedAt
  season       Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  fixture      Fixture? @relation(fields: [fixtureId], references: [id], onDelete: SetNull)
  team         Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([seasonId, teamId])
  @@index([seasonId, position])
}

model OddsMarket {
  id            String          @id @default(cuid())
  fixtureId      String
  provider      String?
  externalRef   String?         @unique
  bookmaker      String
  marketType     String
  suspended      Boolean         @default(false)
  lastSyncedAt   DateTime?
  metadata      Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  fixture        Fixture         @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
  selections     OddsSelection[]

  @@index([fixtureId, bookmaker])
  @@index([bookmaker, marketType])
}

model OddsSelection {
  id              String      @id @default(cuid())
  oddsMarketId    String
  externalRef     String?     @unique
  label           String
  line            Decimal?    @db.Decimal(10, 2)
  priceDecimal    Decimal     @db.Decimal(10, 4)
  isActive        Boolean     @default(true)
  metadata        Json?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  oddsMarket      OddsMarket  @relation(fields: [oddsMarketId], references: [id], onDelete: Cascade)
  slipSelections  BettingSlipSelection[]

  @@index([oddsMarketId, isActive])
}

model ResultSnapshot {
  id              String   @id @default(cuid())
  fixtureId       String   @unique
  homeScore       Int
  awayScore       Int
  statusText      String?
  payload         Json?
  capturedAt      DateTime @default(now())
  fixture         Fixture  @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
}

model CreatorProfile {
  id               String        @id @default(cuid())
  userId           String        @unique
  slug             String        @unique
  bio              String?       @db.Text
  isVerified       Boolean       @default(false)
  activeSlipCount  Int           @default(0)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  bettingSlips     BettingSlip[]

  @@index([isVerified])
}

model InsightPost {
  id             String            @id @default(cuid())
  authorId       String
  title          String
  body           String            @db.Text
  visibility     InsightVisibility @default(PUBLIC)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  author         User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments       InsightComment[]
  likes          InsightLike[]
  reports        Report[]

  @@index([createdAt])
  @@index([authorId, createdAt])
}

model InsightComment {
  id         String      @id @default(cuid())
  postId     String
  authorId   String
  body       String      @db.Text
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  post       InsightPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author     User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model InsightLike {
  postId      String
  userId      String
  createdAt   DateTime   @default(now())
  post        InsightPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
}

model Report {
  id             String       @id @default(cuid())
  postId          String?
  reporterId      String
  targetUserId    String?
  reason          String
  details         String?     @db.Text
  status          ReportStatus @default(OPEN)
  createdAt       DateTime    @default(now())
  resolvedAt      DateTime?
  post            InsightPost? @relation(fields: [postId], references: [id], onDelete: SetNull)
  reporter        User         @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  targetUser      User?        @relation("ReportTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
  moderationActions ModerationAction[]

  @@index([status, createdAt])
}

model ModerationAction {
  id            String               @id @default(cuid())
  reportId       String?
  targetUserId   String?
  actionType     ModerationActionType
  notes          String?             @db.Text
  expiresAt      DateTime?
  createdAt      DateTime            @default(now())
  report         Report?             @relation(fields: [reportId], references: [id], onDelete: SetNull)
  targetUser     User?               @relation("ModerationTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
}

model BettingSlip {
  id                String               @id @default(cuid())
  creatorProfileId  String
  title             String
  description       String?              @db.Text
  status            BettingSlipStatus    @default(DRAFT)
  stakeAmount       Decimal?             @db.Decimal(12, 2)
  unitPrice         Decimal              @default(0) @db.Decimal(12, 2)
  publishedAt       DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  creatorProfile    CreatorProfile       @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)
  selections        BettingSlipSelection[]
  prices            BettingSlipPrice[]
  purchases         BettingSlipPurchase[]
  outcomes          BettingSlipOutcome[]

  @@index([creatorProfileId, status])
  @@index([status, createdAt])
}

model BettingSlipSelection {
  id               String        @id @default(cuid())
  bettingSlipId    String
  fixtureId        String
  oddsSelectionId  String
  createdAt        DateTime      @default(now())
  bettingSlip      BettingSlip   @relation(fields: [bettingSlipId], references: [id], onDelete: Cascade)
  fixture          Fixture       @relation(fields: [fixtureId], references: [id], onDelete: Restrict)
  oddsSelection    OddsSelection @relation(fields: [oddsSelectionId], references: [id], onDelete: Restrict)

  @@unique([bettingSlipId, oddsSelectionId])
  @@index([fixtureId])
}

model BettingSlipPrice {
  id              String      @id @default(cuid())
  bettingSlipId   String
  totalOdds       Decimal     @db.Decimal(12, 4)
  expectedPayout  Decimal?    @db.Decimal(12, 2)
  createdAt       DateTime    @default(now())
  bettingSlip     BettingSlip @relation(fields: [bettingSlipId], references: [id], onDelete: Cascade)

  @@index([bettingSlipId, createdAt])
}

model BettingSlipPurchase {
  id              String         @id @default(cuid())
  bettingSlipId   String
  buyerId         String
  amountPaid      Decimal        @db.Decimal(12, 2)
  status          PurchaseStatus @default(PENDING)
  purchasedAt     DateTime       @default(now())
  bettingSlip     BettingSlip    @relation(fields: [bettingSlipId], references: [id], onDelete: Restrict)
  buyer           User           @relation(fields: [buyerId], references: [id], onDelete: Restrict)
  order           Order?

  @@index([buyerId, purchasedAt])
}

model BettingSlipOutcome {
  id              String        @id @default(cuid())
  bettingSlipId   String
  status          OutcomeStatus @default(OPEN)
  settledAt       DateTime?
  payoutAmount    Decimal?      @db.Decimal(12, 2)
  notes           String?       @db.Text
  bettingSlip     BettingSlip   @relation(fields: [bettingSlipId], references: [id], onDelete: Cascade)

  @@index([bettingSlipId, status])
}

model Payment {
  id               String         @id @default(cuid())
  userId           String
  provider         String
  providerRef      String         @unique
  amount           Decimal        @db.Decimal(12, 2)
  currency         String         @default("USD")
  status           PaymentStatus  @default(PENDING)
  paidAt           DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  user             User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  order            Order?

  @@index([userId, createdAt])
}

model Order {
  id                     String               @id @default(cuid())
  userId                 String
  bettingSlipPurchaseId  String?              @unique
  paymentId              String?              @unique
  totalAmount            Decimal              @db.Decimal(12, 2)
  status                 OrderStatus          @default(CREATED)
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  user                   User                 @relation(fields: [userId], references: [id], onDelete: Restrict)
  bettingSlipPurchase    BettingSlipPurchase? @relation(fields: [bettingSlipPurchaseId], references: [id], onDelete: SetNull)
  payment                Payment?             @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  invoice                Invoice?
}

model Invoice {
  id          String        @id @default(cuid())
  orderId     String        @unique
  number      String        @unique
  amount      Decimal       @db.Decimal(12, 2)
  status      InvoiceStatus @default(DRAFT)
  issuedAt    DateTime?
  dueAt       DateTime?
  paidAt      DateTime?
  createdAt   DateTime      @default(now())
  order       Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  action      String
  entityType  String
  entityId    String
  metadata    Json?
  createdAt   DateTime @default(now())
  actor       User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId, createdAt])
}

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  description String?
  enabled     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SyncJob {
  id            String        @id @default(cuid())
  provider      String        @default("SPORTSMONKS")
  source        String
  bucket        String        @default("manual")
  recordsProcessed Int        @default(0)
  resultSummary Json?
  status        SyncJobStatus @default(PENDING)
  startedAt     DateTime?
  finishedAt    DateTime?
  errorMessage  String?       @db.Text
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  checkpoints   SyncCheckpoint[]

  @@index([source, status, createdAt])
  @@index([provider, bucket, createdAt])
}

model SyncCheckpoint {
  id            String   @id @default(cuid())
  provider      String   @default("SPORTSMONKS")
  key           String
  syncJobId     String?
  cursor        String?
  payload       Json?
  errorMessage  String?  @db.Text
  lastSuccessAt DateTime?
  lastFailureAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  syncJob       SyncJob? @relation(fields: [syncJobId], references: [id], onDelete: SetNull)

  @@unique([provider, key])
  @@index([provider, updatedAt])
}
